# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Linux System Automation
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime logs (generated at runtime, not source code) ─────────────────────
logs/
*.log
*.log.gz

# ── Backup archives (can be huge, belong on the server not in git) ────────────
/var/backups/
*.tar.gz
*.tar.bz2
*.zip

# ── Health reports (generated output, not source) ────────────────────────────
monitoring/reports/
health_report_*.txt

# ── Sensitive config overrides (if you ever make a local settings override) ───
config/settings.local.conf
config/*.secret

# ── Bulk provisioning CSVs (contain usernames/passwords — keep off git) ───────
*.csv
users*.txt

# ── OS clutter ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor/IDE clutter ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~